<footer class="site-footer" data-section-id="{{ section.id }}">

<div class="site-footer__newsletter-bar">
<div class="container">
<div class="site-footer__newsletter-inner" data-animate="fade-up">
<div class="site-footer__newsletter-text">
<h4 class="site-footer__newsletter-title">Join Our Community</h4>
<p>Subscribe for exclusive access to new arrivals, offers & style inspiration.</p>
</div>
<div class="site-footer__newsletter-form-wrap">
{% form 'customer', class: 'site-footer__newsletter-form' %}
<input type="hidden" name="contact[tags]" value="newsletter,footer">
<input type="email" name="contact[email]" class="site-footer__newsletter-input" placeholder="Enter your email address" required autocomplete="email" aria-label="Email address">
<button type="submit" class="site-footer__newsletter-btn">
Subscribe
<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
</button>
{% endform %}
</div>
</div>
</div>
</div>

<div class="container">
<div class="site-footer__grid" data-animate="fade-up">
<div class="site-footer__brand-col">
<a href="{{ routes.root_url }}" class="site-footer__brand">{{ shop.name }}</a>
<p class="site-footer__about">{{ section.settings.about_text }}</p>
{% if section.settings.address_text != blank %}
<p class="site-footer__address">{{ section.settings.address_text }}</p>
{% endif %}
{% if section.settings.whatsapp_number != blank %}
<a href="https://wa.me/{{ section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}" class="site-footer__whatsapp" target="_blank" rel="noopener" aria-label="Chat on WhatsApp">
<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
Chat with us
</a>
{% endif %}
</div>

{% for block in section.blocks %}
<div class="site-footer__menu-col" {{ block.shopify_attributes }}>
<div class="site-footer__heading-wrap">
<h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
<button class="site-footer__toggle" aria-label="Toggle menu">
<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
</button>
</div>
<div class="site-footer__links">
{% assign menu = linklists[block.settings.menu] %}
{% for link in menu.links %}
<a href="{{ link.url }}" class="site-footer__link">{{ link.title }}</a>
{% endfor %}
</div>
</div>
{% endfor %}
</div>

<div class="site-footer__bottom" data-animate="fade-up" data-animate-delay="200">
<p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved</p>
<div class="site-footer__social">
{% if settings.social_facebook != blank %}
<a href="{{ settings.social_facebook }}" class="site-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
</a>
{% endif %}
{% if settings.social_instagram != blank %}
<a href="{{ settings.social_instagram }}" class="site-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
</a>
{% endif %}
{% if settings.social_twitter != blank %}
<a href="{{ settings.social_twitter }}" class="site-footer__social-link" aria-label="Twitter" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
</a>
{% endif %}
{% if settings.social_linkedin != blank %}
<a href="{{ settings.social_linkedin }}" class="site-footer__social-link" aria-label="LinkedIn" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
</a>
{% endif %}
{% if settings.social_pinterest != blank %}
<a href="{{ settings.social_pinterest }}" class="site-footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 12a4 4 0 1 1 8 0c0 3-2 5-4 7"/><line x1="12" y1="12" x2="10" y2="22"/></svg>
</a>
{% endif %}
{% if settings.social_tiktok != blank %}
<a href="{{ settings.social_tiktok }}" class="site-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
</a>
{% endif %}
</div>
<div class="site-footer__payment">
{% for type in shop.enabled_payment_types %}
{{ type | payment_type_svg_tag }}
{% endfor %}
</div>
</div>
</div>
</footer>

{% schema %}
{"name":"Footer","max_blocks":3,"settings":[{"type":"textarea","id":"about_text","label":"About text","default":"We curate premium products for those who appreciate quality, craftsmanship, and timeless design."},{"type":"textarea","id":"address_text","label":"Address"},{"type":"text","id":"whatsapp_number","label":"WhatsApp number","info":"Include country code, e.g. +919876543210"}],"blocks":[{"type":"menu","name":"Menu Column","settings":[{"type":"text","id":"heading","label":"Heading","default":"Quick Links"},{"type":"link_list","id":"menu","label":"Menu","default":"footer"}]}],"default":{"blocks":[{"type":"menu","settings":{"heading":"Customer Care"}},{"type":"menu","settings":{"heading":"Our Company"}},{"type":"menu","settings":{"heading":"Quick Links"}}]}}
{% endschema %}