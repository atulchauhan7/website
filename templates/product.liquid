<div class="product-page">
<div class="container">

<nav class="product-breadcrumbs" aria-label="Breadcrumb">
<a href="{{ routes.root_url }}">Home</a>
<span aria-hidden="true">/</span>
{% if product.collections.size > 0 %}
<a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
<span aria-hidden="true">/</span>
{% endif %}
<span class="product-breadcrumbs__current">{{ product.title | truncate: 40 }}</span>
</nav>

<div class="product-page__grid">
<div class="product-gallery product-gallery--slider">
<div class="product-gallery__viewport">
<div class="product-gallery__track">
{% for image in product.images %}
<div class="product-gallery__slide">
<img 
src="{{ image | image_url: width: 800 }}"
srcset="{{ image | image_url: width: 400 }} 400w,
{{ image | image_url: width: 600 }} 600w,
{{ image | image_url: width: 800 }} 800w,
{{ image | image_url: width: 1200 }} 1200w"
sizes="(max-width: 412px) 100vw, (max-width: 768px) 100vw, 55vw"
alt="{{ image.alt | default: product.title | escape }}" 
width="1200" 
height="{{ 1200 | divided_by: image.aspect_ratio | round }}"
loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
{% if forloop.first %}fetchpriority="high"{% endif %}
decoding="async"
>
</div>
{% else %}
<div class="product-gallery__slide">
{{ 'product-1' | placeholder_svg_tag }}
</div>
{% endfor %}
</div>
</div>
{% if product.images.size > 1 %}
<div class="product-gallery__dots">
{% for image in product.images %}
<button class="product-gallery__dot{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Go to image {{ forloop.index }}"></button>
{% endfor %}
</div>

{% endif %}
</div>

<div class="product-info">
{% if product.vendor != blank %}
<div class="product-info__vendor">{{ product.vendor }}</div>
{% endif %}

<h1 class="product-info__title">{{ product.title }}</h1>

<div class="product-info__price-wrap">
{% if product.compare_at_price > product.price %}
<span class="product-info__price" style="color: #e74c3c;">{{ product.price | money }}</span>
<span class="product-info__compare-price">{{ product.compare_at_price | money }}</span>
<span class="product-info__save-badge">
Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
</span>
{% else %}
<span class="product-info__price">{{ product.price | money }}</span>
{% endif %}
</div>

{% if product.description != blank %}
<div class="product-info__description">
{{ product.description | strip_html | truncate: 300 }}
</div>
{% endif %}

{% form 'product', product, data-add-to-cart: true, data-product-form: true %}
<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

{% unless product.has_only_default_variant %}
<script type="application/json" data-product-variants>{{ product.variants | json }}</script>
<div class="product-info__options">
{% for option in product.options_with_values %}
<div class="product-option" data-option-index="{{ forloop.index0 }}">
<label class="product-option__label">{{ option.name }}</label>
<div class="product-option__values">
{% for value in option.values %}
<span class="product-option__value {% if option.selected_value == value %}selected{% endif %}" data-option-index="{{ forloop.index0 }}" data-value="{{ value }}" role="button" tabindex="0" aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}">
{{ value }}
</span>
{% endfor %}
</div>
</div>
{% endfor %}
</div>
{% endunless %}

<div class="product-info__quantity">
<label class="product-option__label">Quantity</label>
<div class="quantity-selector">
<button type="button" data-qty-minus>&#8722;</button>
<input type="number" name="quantity" value="1" min="1" aria-label="Quantity">
<button type="button" data-qty-plus>+</button>
</div>
</div>

<div class="product-info__cta-group">
<div class="product-info__add-to-cart">
<button type="submit" class="btn btn--primary btn--full btn--large" {% unless product.available %}disabled{% endunless %}>
{% if product.available %}
Add to Cart
{% else %}
Sold Out
{% endif %}
</button>
</div>
{% if product.available %}
<button type="button" class="btn btn--buy-now btn--full btn--large" data-buy-now>
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
Buy Now
</button>
{% endif %}
</div>
{% endform %}

<div class="product-trust">
<div class="product-trust__item">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
<span>Free Shipping Over &#8377;999</span>
</div>
<div class="product-trust__item">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
<span>10-Day Easy Returns</span>
</div>
<div class="product-trust__item">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
<span>Secure Checkout</span>
</div>
<div class="product-trust__item">
<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
<span>COD Available</span>
</div>
</div>

<div class="product-accordion">
{% if product.description != blank %}
<div class="accordion-item open">
<button class="accordion-trigger" type="button" aria-expanded="true">
Description
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
</button>
<div class="accordion-content" style="max-height: 500px;">
<div class="accordion-content__inner">
{{ product.description }}
</div>
</div>
</div>
{% endif %}

<div class="accordion-item">
<button class="accordion-trigger" type="button" aria-expanded="false">
Shipping & Returns
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
</button>
<div class="accordion-content">
<div class="accordion-content__inner">
<p>Free standard shipping on all orders over $100. Express shipping available at checkout. 30-day hassle-free returns on all items.</p>
</div>
</div>
</div>

<div class="accordion-item">
<button class="accordion-trigger" type="button" aria-expanded="false">
Care Instructions
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
</button>
<div class="accordion-content">
<div class="accordion-content__inner">
<p>Please refer to the product label for specific care instructions. For best results, follow the recommended guidelines.</p>
</div>
</div>
</div>
</div>

<div class="product-info__meta">
{% if product.vendor != blank %}
<div class="product-info__meta-item">
<strong>Brand:</strong> {{ product.vendor }}
</div>
{% endif %}
<div class="product-info__meta-item">
<strong>SKU:</strong> {{ product.selected_or_first_available_variant.sku | default: 'N/A' }}
</div>
<div class="product-info__meta-item">
<strong>Type:</strong> {{ product.type | default: 'N/A' }}
</div>
{% if product.tags.size > 0 %}
<div class="product-info__meta-item">
<strong>Tags:</strong> {{ product.tags | join: ', ' }}
</div>
{% endif %}
</div>
</div>
</div>
</div>
</div>

<script type="application/ld+json">
{
"@context": "https://schema.org/",
"@type": "Product",
"name": {{ product.title | json }},
{% if product.featured_image != blank %}"image": {{ product.featured_image | image_url: width: 1200 | json }},{% endif %}
"description": {{ product.description | strip_html | truncate: 250 | json }},
"brand": {
"@type": "Brand",
"name": {{ product.vendor | json }}
},
"offers": {
"@type": "Offer",
"url": {{ request.origin | append: product.url | json }},
"priceCurrency": {{ cart.currency.iso_code | json }},
"price": {{ product.price | divided_by: 100.0 }},
"availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}"
}
}
</script>