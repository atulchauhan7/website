{% comment %}
  Reset Password — Premium Split-Screen Layout
  Kurti / Ethnic Fashion — Production Ready
{% endcomment %}

<div class="rp-page">
  <!-- Decorative Left Panel -->
  <div class="rp-visual" aria-hidden="true">
    <div class="rp-visual__overlay"></div>
    <div class="rp-visual__content">
      <div class="rp-visual__motifs">
        <svg class="rp-motif rp-motif--1" viewBox="0 0 120 120" fill="none"><circle cx="60" cy="60" r="55" stroke="currentColor" stroke-width="1" opacity="0.15"/><circle cx="60" cy="60" r="40" stroke="currentColor" stroke-width="0.8" opacity="0.1"/><circle cx="60" cy="60" r="25" stroke="currentColor" stroke-width="0.6" opacity="0.08"/></svg>
        <svg class="rp-motif rp-motif--2" viewBox="0 0 80 80" fill="none"><path d="M40 5 Q55 20 55 40 Q55 60 40 75 Q25 60 25 40 Q25 20 40 5Z" stroke="currentColor" stroke-width="0.8" opacity="0.12"/><path d="M20 40 Q35 25 40 25 Q45 25 60 40 Q45 55 40 55 Q35 55 20 40Z" stroke="currentColor" stroke-width="0.8" opacity="0.1"/></svg>
        <svg class="rp-motif rp-motif--3" viewBox="0 0 100 100" fill="none"><path d="M50 10 L58 38 L90 38 L64 56 L72 84 L50 68 L28 84 L36 56 L10 38 L42 38Z" stroke="currentColor" stroke-width="0.6" opacity="0.08"/></svg>
      </div>
      <div class="rp-visual__text">
        <span class="rp-visual__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="8" y="20" width="32" height="22" rx="3"/>
            <circle cx="24" cy="32" r="3"/>
            <path d="M16 20V14a8 8 0 1 1 16 0v6"/>
          </svg>
        </span>
        <h2 class="rp-visual__title">Don't Worry</h2>
        <p class="rp-visual__subtitle">We'll help you get back to your account in just a moment</p>
        <div class="rp-visual__divider"></div>
        <p class="rp-visual__tagline">Curated Kurtis &bull; Timeless Elegance</p>
      </div>
    </div>
  </div>

  <!-- Form Panel -->
  <div class="rp-form-panel">
    <div class="rp-form-wrapper">
      <!-- Back Navigation -->
      <a href="{{ routes.account_login_url }}" class="rp-back link-underline" data-animate="fade-right">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>Back to Login</span>
      </a>

      <!-- Header -->
      <div class="rp-header" data-animate="fade-up">
        <div class="rp-header__badge">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h1 class="rp-header__title">Reset Your Password</h1>
        <p class="rp-header__desc">Enter the email address associated with your account and we'll send you a secure link to create a new password.</p>
      </div>

      <!-- Form -->
      <div data-animate="fade-up" data-animate-delay="200">
        {% form 'recover_customer_password' %}
          {% if form.errors %}
            <div class="rp-alert rp-alert--error" role="alert">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              <span>{{ form.errors | default_errors }}</span>
            </div>
          {% endif %}

          {% if form.posted_successfully? %}
            <div class="rp-alert rp-alert--success" role="status">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>We've sent you an email with a link to update your password. Please check your inbox.</span>
            </div>
          {% endif %}

          <div class="rp-field">
            <div class="rp-input-wrap">
              <input
                class="rp-input"
                type="email"
                id="recover-email"
                name="email"
                required
                autocomplete="email"
                placeholder=" "
              >
              <label class="rp-label" for="recover-email">Email Address</label>
              <span class="rp-input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <span class="rp-input-focus"></span>
            </div>
          </div>

          <button type="submit" class="rp-submit" id="rp-submit-btn">
            <span class="rp-submit__text">Send Reset Link</span>
            <span class="rp-submit__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </button>
        {% endform %}
      </div>

      <!-- Trust Signals -->
      <div class="rp-trust" data-animate="fade-up" data-animate-delay="400">
        <div class="rp-trust__item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>Secure & Encrypted</span>
        </div>
        <div class="rp-trust__divider"></div>
        <div class="rp-trust__item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Link expires in 24 hrs</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* === Reset Password — Scoped Styles === */
  .rp-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
    min-height: 100dvh;
  }

  /* — Visual Panel — */
  .rp-visual {
    position: relative;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .rp-visual__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark, var(--color-accent)) 100%);
    opacity: 0.95;
  }

  .rp-visual__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem;
    max-width: 420px;
    animation: rp-fadeIn 1s ease both;
  }

  .rp-visual__motifs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .rp-motif {
    position: absolute;
    color: #fff;
  }

  .rp-motif--1 {
    width: 240px;
    height: 240px;
    top: -40px;
    right: -40px;
    animation: rp-float 8s ease-in-out infinite;
  }

  .rp-motif--2 {
    width: 160px;
    height: 160px;
    bottom: 60px;
    left: -30px;
    animation: rp-float 10s ease-in-out infinite reverse;
  }

  .rp-motif--3 {
    width: 120px;
    height: 120px;
    bottom: -20px;
    right: 30%;
    animation: rp-float 12s ease-in-out infinite 2s;
  }

  .rp-visual__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 50%;
    margin-bottom: 1.75rem;
    animation: rp-pulse 3s ease-in-out infinite;
  }

  .rp-visual__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .rp-visual__subtitle {
    font-size: 0.95rem;
    opacity: 0.8;
    line-height: 1.7;
    margin-bottom: 0;
  }

  .rp-visual__divider {
    width: 40px;
    height: 1.5px;
    background: rgba(255,255,255,0.3);
    margin: 1.5rem auto;
  }

  .rp-visual__tagline {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    opacity: 0.5;
    margin-bottom: 0;
  }

  /* — Form Panel — */
  .rp-form-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    background: var(--color-background);
    position: relative;
  }

  .rp-form-wrapper {
    width: 100%;
    max-width: 420px;
  }

  /* — Back Link — */
  .rp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .rp-back:hover {
    color: var(--color-accent);
    transform: translateX(-3px);
  }

  .rp-back svg {
    transition: transform 0.3s ease;
  }

  .rp-back:hover svg {
    transform: translateX(-3px);
  }

  /* — Header — */
  .rp-header {
    margin-bottom: 2rem;
  }

  .rp-header__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--color-surface);
    border-radius: 50%;
    margin-bottom: 1.25rem;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .rp-header__badge:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 30px rgba(var(--color-accent-rgb, 0,0,0), 0.12);
  }

  .rp-header__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 0.6rem;
    line-height: 1.2;
  }

  .rp-header__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 0;
  }

  /* — Alert Messages — */
  .rp-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: var(--border-radius);
    margin-bottom: 1.5rem;
    font-size: 0.88rem;
    line-height: 1.6;
    animation: rp-slideDown 0.4s ease both;
  }

  .rp-alert svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .rp-alert--error {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  .rp-alert--success {
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  /* — Floating Label Input — */
  .rp-field {
    margin-bottom: 1.75rem;
  }

  .rp-input-wrap {
    position: relative;
  }

  .rp-input {
    width: 100%;
    padding: 18px 16px 8px 44px;
    font-size: 0.95rem;
    font-family: var(--font-body);
    border: 1.5px solid var(--color-border);
    border-radius: var(--border-radius);
    background: transparent;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .rp-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb, 0,0,0), 0.08);
  }

  .rp-label {
    position: absolute;
    left: 44px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left center;
  }

  .rp-input:focus ~ .rp-label,
  .rp-input:not(:placeholder-shown) ~ .rp-label {
    top: 10px;
    transform: translateY(0) scale(0.75);
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .rp-input-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    transition: color 0.3s ease;
    display: flex;
    pointer-events: none;
  }

  .rp-input:focus ~ .rp-input-icon {
    color: var(--color-accent);
  }

  .rp-input-focus {
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 0 0 var(--border-radius) var(--border-radius);
  }

  .rp-input:focus ~ .rp-input-focus {
    left: 0;
    width: 100%;
  }

  /* — Submit Button — */
  .rp-submit {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 15px 32px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--border-radius);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease, transform 0.25s ease, box-shadow 0.3s ease;
  }

  .rp-submit:hover {
    background: var(--color-heading);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  .rp-submit:active {
    transform: translateY(0);
    box-shadow: none;
  }

  .rp-submit__icon {
    display: inline-flex;
    transition: transform 0.3s ease;
  }

  .rp-submit:hover .rp-submit__icon {
    transform: translateX(4px);
  }

  /* Submit shimmer effect */
  .rp-submit::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    transition: none;
  }

  .rp-submit:hover::after {
    animation: rp-shimmer 0.6s ease forwards;
  }

  /* — Trust Signals — */
  .rp-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .rp-trust__item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .rp-trust__item svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .rp-trust__divider {
    width: 1px;
    height: 16px;
    background: var(--color-border);
  }

  /* === Animations === */
  @keyframes rp-fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes rp-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  @keyframes rp-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.15); }
    50% { box-shadow: 0 0 0 15px rgba(255,255,255,0); }
  }

  @keyframes rp-slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes rp-shimmer {
    to { left: 100%; }
  }

  /* === Responsive === */
  @media (max-width: 1024px) {
    .rp-page {
      grid-template-columns: 2fr 3fr;
    }
  }

  @media (max-width: 768px) {
    .rp-page {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .rp-visual {
      min-height: 280px;
      padding: 2rem 1.5rem;
    }

    .rp-visual__content {
      padding: 1.5rem;
    }

    .rp-visual__icon {
      width: 60px;
      height: 60px;
      margin-bottom: 1rem;
    }

    .rp-visual__icon svg {
      width: 32px;
      height: 32px;
    }

    .rp-visual__divider,
    .rp-visual__tagline {
      display: none;
    }

    .rp-form-panel {
      padding: 2rem 1.25rem 3rem;
    }

    .rp-back {
      margin-bottom: 1.75rem;
    }

    .rp-trust {
      flex-direction: column;
      gap: 0.75rem;
    }

    .rp-trust__divider {
      width: 40px;
      height: 1px;
    }
  }

  @media (max-width: 480px) {
    .rp-visual {
      min-height: 220px;
    }

    .rp-visual__title {
      font-size: 1.4rem;
    }

    .rp-visual__subtitle {
      font-size: 0.85rem;
    }

    .rp-header__title {
      font-size: 1.4rem;
    }

    .rp-motif--1 { width: 160px; height: 160px; }
    .rp-motif--2 { width: 100px; height: 100px; }
    .rp-motif--3 { display: none; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .rp-motif,
    .rp-visual__icon,
    .rp-visual__content {
      animation: none !important;
    }

    .rp-submit::after {
      display: none;
    }
  }
</style>