<div class="page-template">
<div class="container container--narrow">
<div class="page-header" data-animate="fade-up">
<h1>Create Account</h1>
</div>

<div data-animate="fade-up" data-animate-delay="200">
{% form 'create_customer' %}
{% if form.errors %}
<div class="form-alert form-alert--error">
{{ form.errors | default_errors }}
</div>
{% endif %}

<div class="grid grid--2">
<div class="form-group">
<label class="form-label" for="reg-first">First Name</label>
<input class="form-input" type="text" id="reg-first" name="customer[first_name]" required>
</div>
<div class="form-group">
<label class="form-label" for="reg-last">Last Name</label>
<input class="form-input" type="text" id="reg-last" name="customer[last_name]" required>
</div>
</div>

<div class="form-group">
<label class="form-label" for="reg-email">Email</label>
<input class="form-input" type="email" id="reg-email" name="customer[email]" required autocomplete="email">
</div>

<div class="form-group">
<label class="form-label" for="reg-password">Password</label>
<input class="form-input" type="password" id="reg-password" name="customer[password]" required minlength="5">
</div>

<button type="submit" class="btn btn--primary btn--full">Create Account</button>

<p class="form-footer">
Already have an account? <a href="{{ routes.account_login_url }}">Sign in</a>
</p>
{% endform %}
</div>
</div>
</div>